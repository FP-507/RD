# Copia este archivo como .env y rellena tus datos

# Tu API key de Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Tus credenciales de ReadWorks (opcional — para login automático)
READWORKS_EMAIL=tu@email.com
READWORKS_PASSWORD=tuContraseña

# true = navegador invisible (ideal para servidor), false = navegador visible (local)
HEADLESS=false

# true = envía la asignación automáticamente al terminar
AUTO_SUBMIT=false
